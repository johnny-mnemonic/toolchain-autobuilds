From feb99ab2cbdffcb438acfafc968acde875565f31 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Fri, 20 Mar 2026 11:19:15 +0100
Subject: [PATCH 39/43] Revert "math: Sync lgammaf with CORE-MATH"

The reverted commit touched a file (`sysdeps/ieee754/flt-32/e_lgammaf_r.c`)
already modified by another reverted commit, see Revert "math: Remove
the SVID error handling [...]" for details. Hence also bring back that file
to the state it had with the just mentioned revert in place.

This reverts commit e5ef7b3c850c6aa621aa0a0b36540571f647d730.
---
 SHARED-FILES                         |  2 +-
 sysdeps/ieee754/flt-32/e_lgammaf_r.c | 30 +++++++++++++++++-----------
 2 files changed, 19 insertions(+), 13 deletions(-)

diff --git a/SHARED-FILES b/SHARED-FILES
index 5a676e1a48..c3e8e0f5ae 100644
--- a/SHARED-FILES
+++ b/SHARED-FILES
@@ -272,7 +272,7 @@ core-math:
   sysdeps/ieee754/flt-32/e_coshf.c
   # src/binary32/tgamma/tgammaf.c, revision 8ea8ea35
   sysdeps/ieee754/flt-32/e_gammaf_r.c
-  # src/binary32/lgamma/lgammaf.c, revision 8ea8ea35
+  # src/binary32/lgamma/lgammaf.c, revision bc385c2
   sysdeps/ieee754/flt-32/e_lgammaf_r.c
   # src/binary32/log10/log10f.c, revision ebff4c43
   sysdeps/ieee754/flt-32/e_log10f.c
diff --git a/sysdeps/ieee754/flt-32/e_lgammaf_r.c b/sysdeps/ieee754/flt-32/e_lgammaf_r.c
index cc7611c3f6..5576035911 100644
--- a/sysdeps/ieee754/flt-32/e_lgammaf_r.c
+++ b/sysdeps/ieee754/flt-32/e_lgammaf_r.c
@@ -1,10 +1,10 @@
 /* Correctly-rounded logarithm of the absolute value of the gamma function
    for binary32 value.
 
-Copyright (c) 2023-2026 Alexei Sibidanov.
+Copyright (c) 2023, 2024 Alexei Sibidanov.
 
 This file is part of the CORE-MATH project
-project (file src/binary32/lgamma/lgammaf.c, revision 8ea8ea35).
+project (file src/binary32/lgamma/lgammaf.c, revision bc385c2).
 
 Permission is hereby granted, free of charge, to any person obtaining a copy
 of this software and associated documentation files (the "Software"), to deal
@@ -157,7 +157,7 @@ __ieee754_lgammaf_r (float x, int *signgamp)
       return x + x; /* nan */
     }
   if (__glibc_unlikely (fx == x))
-    { /* x integer */
+    {
       if (x <= 0.0f)
 	{
 	  *signgamp = asuint (x) >> 31 ? -1 : 1;
@@ -202,7 +202,7 @@ __ieee754_lgammaf_r (float x, int *signgamp)
       f = (c0 * s) * as_r8 (s, rn) / as_r8 (s, rd) - as_ln (z);
     }
   else
-    { /* |x| >= 0x1.52p-1 */
+    {
       if (ax > 0x1.afc1ap+1f)
 	{
 	  if (__glibc_unlikely (x >= 0x1.895f1cp+121f))
@@ -277,6 +277,12 @@ __ieee754_lgammaf_r (float x, int *signgamp)
 	      -0x1.3a6c8295b4445p-1, -0x1.da44e8b810024p-3,
 	      -0x1.9061e81c77e4ap-5
 	    };
+	  if (x < 0.0f)
+	    {
+	      int ni = floorf (-2 * x);
+	      if ((ni & 1) == 0 && ni == -2 * x)
+		return __math_divzerof (0);
+	    }
 	  const double c0 = 0x1.3cc0e6a0106b3p+2;
 	  static const double rd[] =
 	    {
@@ -352,15 +358,15 @@ __ieee754_lgammaf_r (float x, int *signgamp)
   if (__glibc_unlikely (tl <= 31u))
     {
       t = asuint (x);
-      int a = 0, b = array_length (tb);
-      /* invariant: t.u < tb[0].x.u or tb[a].x.u <= t.u < tb[b].x.u */
-      while (a + 1 < b)
-	{
-	  int i = (a + b) / 2;
-	  if (t < asuint (tb[i].x))
-	    b = i;
+      int a = 0, b = array_length (tb) - 1;
+      while (a < b)
+	{ /* Binary search.  */
+	  int m = (a + b) >> 1;
+	  uint32_t tbi = asuint (tb[m].x);
+	  if (t > tbi)
+	    a = m + 1;
 	  else
-	    a = i;
+	    b = m;
 	}
       if (t == asuint (tb[a].x))
 	return tb[a].f + tb[a].df;
-- 
