From 7ed66fa9d8d24fbae4eb28630ed2bcb8675fcc92 Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Sat, 21 Mar 2026 11:40:56 +0100
Subject: [PATCH 40/44] Revert "math: Fix spurious overflow and missing errno
 for lgammaf"

The reverted commit touched a file (`sysdeps/ieee754/flt-32/e_lgammaf_r.c`)
already modified by two other reverted commits, see Revert "math: Remove
the SVID error handling [...]" and "Revert "math: Sync lgammaf with
CORE-MATH" (just before this one) for details. Hence also bring back that
file to its original state before the reverted commits happened.

This reverts commit 19781c22211c6db827eefc240cb6724b5512fc6b.
---
 math/auto-libm-test-in         |  1 -
 math/auto-libm-test-out-lgamma | 25 -------------------------
 2 files changed, 26 deletions(-)

diff --git a/math/auto-libm-test-in b/math/auto-libm-test-in
index 4f38095453..39c66c9192 100644
--- a/math/auto-libm-test-in
+++ b/math/auto-libm-test-in
@@ -6994,7 +6994,6 @@ lgamma -0x3.ec4298p+0
 lgamma 0x1.ecf3fep-73
 lgamma 0x1.58ace8p+112
 lgamma -0x1.efc2a2p+14
-lgamma 0x1.895f1cp+121
 
 # Values +/- 10ulp from overflow threshold.  (Values very close to
 # overflow threshold produce results very close of that threshold,
diff --git a/math/auto-libm-test-out-lgamma b/math/auto-libm-test-out-lgamma
index fed3f86c6c..d27c186639 100644
--- a/math/auto-libm-test-out-lgamma
+++ b/math/auto-libm-test-out-lgamma
