From 6f13272f42fa49a1174647d8b3dd2a35c2fc350d Mon Sep 17 00:00:00 2001
From: Johnny Mnemonic <jm@machine-hall.org>
Date: Sat, 21 Mar 2026 11:40:56 +0100
Subject: [PATCH 40/41] Revert "math: Fix spurious overflow and missing errno
 for lgammaf"

The reverted commit touched a file (`sysdeps/ieee754/flt-32/e_lgammaf_r.c`)
already modified by two other reverted commits, see Revert "math: Remove
the SVID error handling [...]" and "Revert "math: Sync lgammaf with
CORE-MATH" (just before this one) for details. Hence also bring back that
file to its original state before the reverted commits happened.

This reverts commit 19781c22211c6db827eefc240cb6724b5512fc6b.
---
 math/auto-libm-test-in               |  1 -
 math/auto-libm-test-out-lgamma       | 25 -------------------------
 sysdeps/ieee754/flt-32/e_lgammaf_r.c | 19 +++++--------------
 3 files changed, 5 insertions(+), 40 deletions(-)

diff --git a/math/auto-libm-test-in b/math/auto-libm-test-in
index 4f38095453..39c66c9192 100644
--- a/math/auto-libm-test-in
+++ b/math/auto-libm-test-in
@@ -6994,7 +6994,6 @@ lgamma -0x3.ec4298p+0
 lgamma 0x1.ecf3fep-73
 lgamma 0x1.58ace8p+112
 lgamma -0x1.efc2a2p+14
-lgamma 0x1.895f1cp+121
 
 # Values +/- 10ulp from overflow threshold.  (Values very close to
 # overflow threshold produce results very close of that threshold,
diff --git a/math/auto-libm-test-out-lgamma b/math/auto-libm-test-out-lgamma
index fed3f86c6c..d27c186639 100644
--- a/math/auto-libm-test-out-lgamma
+++ b/math/auto-libm-test-out-lgamma
@@ -2301,31 +2301,6 @@ lgamma -0x1.efc2a2p+14
 = lgamma tonearest ibm128 -0x7.bf0a88p+12 : -0x4.88b6f00000005971e29c3b8dd8p+16 -1 : inexact-ok
 = lgamma towardzero ibm128 -0x7.bf0a88p+12 : -0x4.88b6f00000005971e29c3b8dd8p+16 -1 : inexact-ok
 = lgamma upward ibm128 -0x7.bf0a88p+12 : -0x4.88b6f00000005971e29c3b8dd8p+16 -1 : inexact-ok
-lgamma 0x1.895f1cp+121
-= lgamma downward binary32 0x3.12be38p+120 : 0xf.fffffp+124 1 : inexact-ok
-= lgamma tonearest binary32 0x3.12be38p+120 : plus_infty 1 : inexact-ok overflow errno-erange
-= lgamma towardzero binary32 0x3.12be38p+120 : 0xf.fffffp+124 1 : inexact-ok
-= lgamma upward binary32 0x3.12be38p+120 : plus_infty 1 : inexact-ok overflow errno-erange
-= lgamma downward binary64 0x3.12be38p+120 : 0xf.fffffbf5af3fp+124 1 : inexact-ok
-= lgamma tonearest binary64 0x3.12be38p+120 : 0xf.fffffbf5af3f8p+124 1 : inexact-ok
-= lgamma towardzero binary64 0x3.12be38p+120 : 0xf.fffffbf5af3fp+124 1 : inexact-ok
-= lgamma upward binary64 0x3.12be38p+120 : 0xf.fffffbf5af3f8p+124 1 : inexact-ok
-= lgamma downward intel96 0x3.12be38p+120 : 0xf.fffffbf5af3f533p+124 1 : inexact-ok
-= lgamma tonearest intel96 0x3.12be38p+120 : 0xf.fffffbf5af3f534p+124 1 : inexact-ok
-= lgamma towardzero intel96 0x3.12be38p+120 : 0xf.fffffbf5af3f533p+124 1 : inexact-ok
-= lgamma upward intel96 0x3.12be38p+120 : 0xf.fffffbf5af3f534p+124 1 : inexact-ok
-= lgamma downward m68k96 0x3.12be38p+120 : 0xf.fffffbf5af3f533p+124 1 : inexact-ok
-= lgamma tonearest m68k96 0x3.12be38p+120 : 0xf.fffffbf5af3f534p+124 1 : inexact-ok
-= lgamma towardzero m68k96 0x3.12be38p+120 : 0xf.fffffbf5af3f533p+124 1 : inexact-ok
-= lgamma upward m68k96 0x3.12be38p+120 : 0xf.fffffbf5af3f534p+124 1 : inexact-ok
-= lgamma downward binary128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7ed8p+124 1 : inexact-ok
-= lgamma tonearest binary128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7ed8p+124 1 : inexact-ok
-= lgamma towardzero binary128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7ed8p+124 1 : inexact-ok
-= lgamma upward binary128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7eep+124 1 : inexact-ok
-= lgamma downward ibm128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7cp+124 1 : inexact-ok
-= lgamma tonearest ibm128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc8p+124 1 : inexact-ok
-= lgamma towardzero ibm128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc7cp+124 1 : inexact-ok
-= lgamma upward ibm128 0x3.12be38p+120 : 0xf.fffffbf5af3f533cd835e6dc8p+124 1 : inexact-ok
 lgamma 0x3.12be0cp+120
 = lgamma downward binary32 0x3.12be0cp+120 : 0xf.ffff1p+124 1 : inexact-ok
 = lgamma tonearest binary32 0x3.12be0cp+120 : 0xf.ffff1p+124 1 : inexact-ok
diff --git a/sysdeps/ieee754/flt-32/e_lgammaf_r.c b/sysdeps/ieee754/flt-32/e_lgammaf_r.c
index 33e710f103..cddd9d078d 100644
--- a/sysdeps/ieee754/flt-32/e_lgammaf_r.c
+++ b/sysdeps/ieee754/flt-32/e_lgammaf_r.c
@@ -205,20 +205,11 @@ __ieee754_lgammaf_r (float x, int *signgamp)
     {
       if (ax > 0x1.afc1ap+1f)
 	{
-	  if (__glibc_unlikely (x >= 0x1.895f1cp+121f))
-	    {
-	      /* for x=0x1.895f1cp+121, lgamma(x) < 2^128, thus there is no
-		 overflow for rounding towards zero or downwards.
-		 The following expression overflows for x > 0x1.895f1cp+121
-		 or x = 0x1.895f1cp+121 and rounding to nearest or away,
-		 and does not overflow for x = 0x1.895f1cp+121 and rounding
-		 towards zero */
-	      float r = fmaf (x, 0x1.4d3398p+6f, 0x1.10f35ep+103f);
-	      if (x > 0x1.895f1cp+121f || (x == 0x1.895f1cp+121f &&
-					   x * 5.0f >= 0x1.ebb6e4p+123))
-		return __math_oflowf (0);
-	      return r;
-	    }
+	  if (__glibc_unlikely (x > 0x1.895f1cp+121f))
+	    return math_narrow_eval (0x1p127f * 0x1p127f);
+	  /* |x|>=2**23, must be -integer */
+	  if (__glibc_unlikely (x < 0.0f && ax > 0x1p+23f))
+	    return __math_divzerof (0);
 	  double lz = as_ln (z);
 	  f = (z - 0.5) * (lz - 1) + 0x1.acfe390c97d69p-2;
 	  if (ax < 0x1.0p+20f)
-- 
2.25.1

