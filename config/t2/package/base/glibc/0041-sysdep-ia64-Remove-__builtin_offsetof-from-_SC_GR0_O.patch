From b1eb49331bddd50732873164c2a33ca996a76389 Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Sat, 21 Mar 2026 15:18:03 +0100
Subject: [PATCH 41/43] sysdep/ia64: Remove __builtin_offsetof from
 _SC_GR0_OFFSET

ia64 uses __builtin_offsetof in a struct field size in sys/ucontext.h on
GCC 3.5+. This breaks some code analyzers, e.g. g-ir-scanner, and is not
present on any other architecture.

Remove the __builtin_offsetof use, keeping only the expanded standard
pattern for offsetof(). This is safe, since the pattern always works
with GCC and the part of the code is guarded with __GNUC__; non-GNU
compilers use a hard-defined offset instead.

Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 sysdeps/unix/sysv/linux/ia64/sys/ucontext.h | 5 +----
 1 file changed, 1 insertion(+), 4 deletions(-)

diff --git a/sysdeps/unix/sysv/linux/ia64/sys/ucontext.h b/sysdeps/unix/sysv/linux/ia64/sys/ucontext.h
index e890327a04..cc30a1e75f 100644
--- a/sysdeps/unix/sysv/linux/ia64/sys/ucontext.h
+++ b/sysdeps/unix/sysv/linux/ia64/sys/ucontext.h
@@ -72,10 +72,7 @@ typedef struct
     unsigned long int __ctx(sc_mask);
   } mcontext_t;
 
-#if __GNUC_PREREQ (3, 5)
-# define _SC_GR0_OFFSET	\
-	__builtin_offsetof (mcontext_t, __ctx(sc_gr)[0])
-#elif defined __GNUC__
+#ifdef __GNUC__
 # define _SC_GR0_OFFSET	\
 	(((char *) &((mcontext_t *) 0)->__ctx(sc_gr)[0]) - (char *) 0)
 #else
-- 
